# MyFunctions.cmake - файл с пользовательскими функциями для CMake.
# Позволяет переиспользовать логику в разных CMakeLists.txt файлах проекта, соблюдая принцип DRY (Don't Repeat Yourself).

# Функция для автоматического сбора всех исходных (.c) и заголовочных (.h) файлов в указанной директории.
# Принимает два аргумента: 
#   1. dir - путь к директории для поиска.
#   2. result_var - имя переменной, в которую будет сохранен результат.
function(get_all_sources dir result_var)
    # Команда file(GLOB ...) ищет файлы по маске. 
    # CONFIGURE_DEPENDS заставляет CMake перепроверять наличие новых или удаленных файлов 
    # при каждом запуске сборки, что удобно при добавлении файлов в папку src без ручного перезапуска cmake.
    file(GLOB SOURCE_FILES CONFIGURE_DEPENDS
        "${dir}/*.c"
        "${dir}/*.h"
    )
    
    # Возвращаем найденный список файлов в вызывающий CMakeLists.txt.
    # PARENT_SCOPE обязателен, иначе переменная останется локальной внутри функции и исчезнет после её завершения.
    set(${result_var} ${SOURCE_FILES} PARENT_SCOPE)
endfunction()